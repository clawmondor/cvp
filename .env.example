# Copy to .env for local dev. Never commit the real .env.

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev defaults to SQLite. Uncomment and set for Postgres testing.
# DATABASE_URL=postgresql+psycopg://cvp:cvp@localhost:5432/cvp

# ── Application ──────────────────────────────────────────────────────────────
# DEPRECATED: Anthropic API direct access. Use OpenRouter instead (see below).
# ANTHROPIC_API_KEY=
# VISION_MODEL=claude-opus-4-6
# VISION_MODEL_FALLBACK=claude-sonnet-4-6
PORT=8000
UPLOAD_DIR=./data/uploads
EXPORT_DIR=./data/exports
COMPANY_NAME=Contents Valuation LLC
COMPANY_ADDRESS=
COMPANY_EMAIL=
COMPANY_PHONE=

# Public base URL — used for MFA QR issuer, invite links, etc.
PUBLIC_BASE_URL=http://localhost:8000

# ── Authentication ────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=7

# Generate with: uv run python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MFA_ENCRYPTION_KEY=

# Set to false for local HTTP development (cookies require HTTPS when true)
COOKIE_SECURE=false

# development | production
# ENVIRONMENT=dev enables the AUTO_LOGIN_USER_ID bypass — never set in production.
ENVIRONMENT=development
# AUTO_LOGIN_USER_ID=

# ── First-deploy bootstrap (Railway) ─────────────────────────────────────────
# Used ONLY by `uv run bootstrap-admin` on first deploy.
# Remove INITIAL_ADMIN_PASSWORD after the first admin has logged in.
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=

# ── OpenRouter — vision provider ──────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_REFERER=https://your-domain.example
OPENROUTER_APP_TITLE=CVP

# ── SerpAPI — Google Shopping provider provider
SERP_API_KEY=