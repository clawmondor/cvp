# ── Application ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
VISION_MODEL=claude-opus-4-6
VISION_MODEL_FALLBACK=claude-sonnet-4-6
PORT=8000
DATABASE_URL=sqlite:///./data/cvp.db
UPLOAD_DIR=./data/uploads
EXPORT_DIR=./data/exports
COMPANY_NAME=Contents Valuation LLC
COMPANY_ADDRESS=123 Main St, El Segundo, CA 90245
COMPANY_EMAIL=hello@example.com
COMPANY_PHONE=+1 (555) 555-0100
# Base URL prepended to invite registration links:
PUBLIC_BASE_URL=http://localhost:8000

# ── Authentication ────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=7

# Generate with: uv run python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MFA_ENCRYPTION_KEY=

# Set to false for local HTTP development (cookies require HTTPS when true)
COOKIE_SECURE=false

# ── Local development only ────────────────────────────────────────────────────
# ENVIRONMENT=dev enables the AUTO_LOGIN_USER_ID bypass — never set in production.
# Get the UUID by running the bootstrap script in README step 6, then paste it here.
ENVIRONMENT=dev
# AUTO_LOGIN_USER_ID=
